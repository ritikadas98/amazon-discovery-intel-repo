# Vertex AI (auth via ADC; Cloud Run uses its runtime SA, local dev uses the JSON below)
VERTEX_PROJECT_ID=
VERTEX_REGION=asia-south1
VERTEX_MODEL=gemini-2.5-flash

# Google APIs (service account JSON path — only set locally; Cloud Run picks up its runtime SA)
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json
SHEETS_DOCUMENT_ID=1onm967wGWmy2YpwNJxr_UEDkFGb8Ibx22unKLXuKj3g
SHEETS_SIGNALS_TAB=Signals
SHEETS_DIGESTS_TAB=Weekly Digests

# SMTP (Gmail app password — no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Runtime
DEFAULT_RECIPIENT=
PORT=3000
USE_MOCK=true
CRON_SCHEDULE=0 9 1 * *
CORS_ORIGIN=*
